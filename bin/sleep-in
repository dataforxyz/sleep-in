#!/usr/bin/env bash
set -euo pipefail

input=$(omarchy-menu-input "Sleep in (e.g. 90, 2h, 30m, 1h30)" --width 360) || exit 0
input=$(echo "$input" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]')
[[ -z "$input" ]] && exit 0

mins=0
if [[ "$input" =~ ^([0-9]+)h([0-9]+)m?$ ]]; then
  mins=$((BASH_REMATCH[1] * 60 + BASH_REMATCH[2]))
elif [[ "$input" =~ ^([0-9]+)h$ ]]; then
  mins=$((BASH_REMATCH[1] * 60))
elif [[ "$input" =~ ^([0-9]+)m?$ ]]; then
  mins=${BASH_REMATCH[1]}
else
  notify-send "Sleep timer" "Couldn't parse: $input" -u critical
  exit 1
fi

if ((mins < 1)); then
  notify-send "Sleep timer" "Duration must be at least 1 minute" -u critical
  exit 1
fi

fire="$HOME/.local/bin/sleep-in-fire"
if [[ ! -x "$fire" ]]; then
  notify-send "Sleep timer" "Missing executable: $fire" -u critical
  exit 1
fi

unit="sleep-in-$(date +%s)"
run_args=(
  systemd-run
  --user
  --collect
  --unit="$unit"
  --description="Sleep In: suspend after ${mins}m"
  --on-active="${mins}m"
)

# Preserve the current Hyprland session coordinates for the future timer fire.
# This lets sleep-in-fire ask Hyprland to spawn the suspend request from the
# active desktop session, which avoids invisible auth prompts from user services.
for name in HYPRLAND_INSTANCE_SIGNATURE WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE DISPLAY; do
  if [[ -n "${!name:-}" ]]; then
    run_args+=(--setenv="$name=${!name}")
  fi
done

"${run_args[@]}" "$fire" >/dev/null
pkill -RTMIN+11 waybar 2>/dev/null || true

when=$(date -d "+${mins} minutes" "+%H:%M")
notify-send "󰒲 Suspend scheduled" "In ${mins} min (at ${when})\nClick the sleep timer in the top bar to cancel"
