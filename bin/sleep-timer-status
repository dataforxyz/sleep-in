#!/usr/bin/env python3
"""Emit the current Sleep In timer as a Waybar custom-module payload."""

import datetime as dt
import html
import json
import subprocess
import time


def sleep_in_status():
    proc = subprocess.run(
        ["sleep-in", "status"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    if proc.returncode != 0:
        return None

    fields = proc.stdout.strip().split("\t")
    if len(fields) != 3 or fields[0] != "scheduled":
        return None

    try:
        return int(fields[1]), int(fields[2])
    except ValueError:
        return None


def duration(seconds):
    if seconds < 60:
        return "<1m"
    minutes = (seconds + 59) // 60
    if minutes < 60:
        return f"{minutes}m"
    hours, minutes = divmod(minutes, 60)
    return f"{hours}h" if minutes == 0 else f"{hours}h{minutes:02d}"


def emit(payload):
    print(json.dumps(payload, ensure_ascii=False))


def main():
    status = sleep_in_status()
    if status is None:
        emit({"text": "", "tooltip": "", "class": "hidden"})
        return

    deadline, requested_minutes = status
    remaining = max(0, deadline - int(time.time()))
    when = dt.datetime.fromtimestamp(deadline).strftime("%H:%M")
    tooltip = (
        f"Suspend timer\n"
        f"{duration(remaining)} remaining — suspends at {when}\n"
        f"Originally scheduled for {requested_minutes}m\n\n"
        "Click to cancel"
    )
    emit(
        {
            "text": f"󰒲 {duration(remaining)}",
            "tooltip": html.escape(tooltip),
            "class": "active",
            "alt": "sleep-timer",
        }
    )


if __name__ == "__main__":
    main()
